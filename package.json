{
  "name": "claire",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @claire/db db:generate",
    "db:push": "pnpm --filter @claire/db db:push",
    "db:seed": "pnpm --filter @claire/db db:seed",
    "auth:generate": "pnpm --filter @claire/auth auth:generate"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
